{
  "name": "pipewatch",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:unit": "turbo test:unit",
    "test:integration": "bash scripts/test-with-deps.sh node scripts/test-integration.mjs",
    "test:e2e": "bash scripts/test-e2e.sh",
    "ci:preflight": "bash scripts/ci-preflight.sh",
    "ci:gate": "bash scripts/ci-gate.sh",
    "ci:verify-scoped": "bash scripts/ci-verify-scoped.sh",
    "i18n:validate": "node --experimental-strip-types scripts/i18n-validate.ts",
    "i18n:check:hardcoded": "node --experimental-strip-types scripts/i18n-check-hardcoded.ts",
    "setup:hooks": "bash scripts/setup-hooks.sh",
    "bump:versions": "node scripts/bump-package-versions.mjs",
    "bump:versions:force": "node scripts/bump-package-versions.mjs --force",
    "check:push-version-bumps": "node scripts/check-push-version-bumps.mjs",
    "test:scripts": "bash -c 'cd packages/config && pnpm exec vitest run --config ../../scripts/vitest.config.ts'",
    "db:generate": "turbo db:generate --filter=@pipewatch/db",
    "db:migrate": "turbo db:migrate --filter=@pipewatch/db"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1",
      "@opentelemetry/core": ">=2.8.0",
      "esbuild": ">=0.28.1"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@reportportal/agent-js-playwright": "^5.1.11",
    "@reportportal/client-javascript": "5.5.11",
    "@pipewatch/db": "workspace:*",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
