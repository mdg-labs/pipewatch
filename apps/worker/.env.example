# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=

# Runtime environment
NODE_ENV=development

# PostgreSQL connection (runtime)
DATABASE_URL=

# Redis connection
REDIS_URL=

# AES-256-GCM key for encrypting sensitive values at rest (min 32 chars)
ENCRYPTION_KEY=

# Sentry DSN — optional; no-op when unset
SENTRY_DSN=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Self-hosted ingestion mode override (webhook | polling)
PIPEWATCH_MODE=webhook

# Pipeline run retention in days (default: 30)
RETENTION_DAYS=30
