{
  "name": "@pipewatch/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./queues": {
      "types": "./dist/queues/index.d.ts",
      "default": "./dist/queues/index.js"
    },
    "./queues/backfill": {
      "types": "./dist/queues/backfill.d.ts",
      "default": "./dist/queues/backfill.js"
    },
    "./queues/backfill.js": {
      "types": "./dist/queues/backfill.d.ts",
      "default": "./dist/queues/backfill.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "node --watch dist/index.js",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --build",
    "deploy:worker": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@pipewatch/config": "workspace:*",
    "@pipewatch/db": "workspace:*",
    "@pipewatch/types": "workspace:*",
    "@pipewatch/utils": "workspace:*",
    "@sentry/node": "^9.15.0",
    "bullmq": "^5.41.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.0.5"
  }
}
