{
  "name": "@pipewatch/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./queues": {
      "types": "./dist/queues/index.d.ts",
      "default": "./dist/queues/index.js"
    },
    "./queues/backfill": {
      "types": "./dist/queues/backfill.d.ts",
      "default": "./dist/queues/backfill.js"
    },
    "./queues/backfill.js": {
      "types": "./dist/queues/backfill.d.ts",
      "default": "./dist/queues/backfill.js"
    },
    "./queues/polling": {
      "types": "./dist/queues/polling.d.ts",
      "default": "./dist/queues/polling.js"
    },
    "./queues/polling.js": {
      "types": "./dist/queues/polling.d.ts",
      "default": "./dist/queues/polling.js"
    },
    "./services/polling/lifecycle": {
      "types": "./dist/services/polling/lifecycle.d.ts",
      "default": "./dist/services/polling/lifecycle.js"
    },
    "./services/polling/lifecycle.js": {
      "types": "./dist/services/polling/lifecycle.d.ts",
      "default": "./dist/services/polling/lifecycle.js"
    },
    "./webhook-delivery-idempotency": {
      "types": "./dist/lib/webhook-delivery-idempotency.d.ts",
      "default": "./dist/lib/webhook-delivery-idempotency.js"
    },
    "./webhook-delivery-idempotency.js": {
      "types": "./dist/lib/webhook-delivery-idempotency.d.ts",
      "default": "./dist/lib/webhook-delivery-idempotency.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "node --watch dist/index.js",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --build",
    "deploy:worker": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@pipewatch/config": "workspace:*",
    "@pipewatch/db": "workspace:*",
    "@pipewatch/github-app-auth": "workspace:*",
    "@pipewatch/types": "workspace:*",
    "@pipewatch/utils": "workspace:*",
    "@sentry/node": "^10.58.0",
    "bullmq": "^5.41.0",
    "hono": "catalog:",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.0.5"
  }
}
