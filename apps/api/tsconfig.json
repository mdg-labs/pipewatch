{
  "extends": "@pipewatch/config/typescript",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "paths": {
      "@pipewatch/worker/queues/backfill.js": ["../worker/src/queues/backfill.ts"],
      "@pipewatch/worker/queues/polling.js": ["../worker/src/queues/polling.ts"],
      "@pipewatch/worker/services/polling/lifecycle.js": [
        "../worker/src/services/polling/lifecycle.ts"
      ]
    }
  },
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/db" },
    { "path": "../../packages/types" },
    { "path": "../../packages/utils" },
    { "path": "../worker" }
  ],
  "include": ["src"]
}
