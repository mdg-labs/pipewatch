# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=

# Runtime environment
NODE_ENV=development

# HTTP listen port
PORT=3001

# PostgreSQL connection (runtime)
DATABASE_URL=

# Redis connection
REDIS_URL=

# AES-256-GCM key for encrypting sensitive values at rest (min 32 chars)
ENCRYPTION_KEY=

# Sentry DSN — optional; no-op when unset
SENTRY_DSN=

# HS256 signing secrets for access and refresh tokens (min 32 chars each)
JWT_SECRET=
JWT_REFRESH_SECRET=

# GitHub App credentials — runtime names (CE/local and Fly apps)
# Phase/GHA storage uses GH_* keys; sync-secrets maps GH_* → GITHUB_* on Fly (Decision #33)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Public URLs
APP_URL=
MARKETING_URL=
# Public API origin — OAuth callbacks; must match GitHub App callback host (same as NEXT_PUBLIC_API_URL on web)
PUBLIC_API_URL=

# Email — optional; features degrade gracefully when SMTP_HOST is unset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Postmark broadcast stream (cloud)
POSTMARK_API_KEY=
POSTMARK_BROADCAST_STREAM=
POSTMARK_WEBHOOK_SECRET=

# Stripe billing (cloud only — required in staging/production)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Self-hosted ingestion mode override (webhook | polling)
PIPEWATCH_MODE=webhook
