    "@pipewatch/utils": "workspace:*",
    "@pipewatch/worker": "workspace:*",
    "@scalar/hono-api-reference": "^0.11.3",
    "@sentry/node": "^9.15.0",
    "drizzle-orm": "^0.45.2",
    "hono": "catalog:",
    "ioredis": "^5.10.1",
    "jose": "^6.0.11",
    "nodemailer": "^9.0.0",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^8.0.1",
    "eslint": "catalog:",
