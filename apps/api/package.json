{
  "name": "@pipewatch/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "dev": "node --watch dist/index.js",
    "lint": "eslint .",
    "start": "node dist/index.js",
