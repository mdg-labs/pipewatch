# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=

# Runtime environment
NODE_ENV=development

# API base URL (required in staging/production)
NEXT_PUBLIC_API_URL=

# Sentry DSN — optional; no-op when unset
# Phase/GHA storage: SENTRY_DSN_WEB — sync-secrets maps to runtime SENTRY_DSN on Wrangler
SENTRY_DSN=
