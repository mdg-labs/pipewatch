{
  "name": "@pipewatch/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:web && pnpm run build:server",
    "build:server": "tsc --build",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "vite --config web/vite.config.ts",
    "dev:server": "pnpm run build:server && node --watch dist/index.js",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --build && tsc --noEmit -p web/tsconfig.json",
    "deploy:admin": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@pipewatch/config": "workspace:*",
    "@pipewatch/ui": "workspace:*",
    "@pipewatch/db": "workspace:*",
    "@pipewatch/db-admin": "workspace:*",
    "@pipewatch/github-app-auth": "workspace:*",
    "@pipewatch/utils": "workspace:*",
    "@sentry/node": "^10.58.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.41.0",
    "drizzle-orm": "^0.45.2",
    "hono": "catalog:",
    "ioredis": "^5.10.1",
    "nodemailer": "^9.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "^7.6.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "catalog:",
    "postgres": "^3.4.9",
    "happy-dom": "^20.8.9",
    "typescript": "catalog:",
    "vite": "^6.2.0",
    "vitest": "^3.0.5"
  }
}
