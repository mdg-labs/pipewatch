# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=

# Runtime environment
NODE_ENV=development

# Marketing CTA behaviour (waitlist | live)
LAUNCH_MODE=waitlist

# Cloud app origin for Sign in / Get started links (Astro PUBLIC_ prefix)
PUBLIC_APP_URL=

# Umami analytics (cloud only — required in staging/production)
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
