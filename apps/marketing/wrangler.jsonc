{
  "$schema": "../node_modules/wrangler/config-schema.json",
  // Dev / astro dev only — production deploy uses dist/server/wrangler.json after `astro build`.
  "name": "pipewatch-staging-marketing",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
