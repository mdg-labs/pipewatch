# PipeWatch CE — copy to .env before `docker compose up -d`
# Per-app examples for local dev: apps/*/.env.example
# Full reference: docs/internal/PipeWatch_MVP_PRD.md §23

# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=ce

# AES-256-GCM key for encrypting sensitive values at rest (min 32 chars)
ENCRYPTION_KEY=

# HS256 signing secrets for access and refresh tokens (min 32 chars each)
JWT_SECRET=
JWT_REFRESH_SECRET=

# GitHub App credentials (create a GitHub App — see README CE quickstart)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Public URLs — set to your reachable hostnames in production
APP_URL=
MARKETING_URL=
NEXT_PUBLIC_API_URL=

# Self-hosted ingestion mode (api, worker): webhook (default) | polling
# Use polling when CE cannot expose a public webhook endpoint (PRD §16, §23)
PIPEWATCH_MODE=webhook

# Pipeline run retention in days (worker; default: 30)
RETENTION_DAYS=30

# Email — optional; invite links shown in UI when SMTP_HOST is unset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry DSN — optional; no-op when unset (api, worker, web)
SENTRY_DSN=
