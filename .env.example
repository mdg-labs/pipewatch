# Root env reference — per-app examples live under apps/*/.env.example
# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=

# AES-256-GCM key for encrypting sensitive values at rest (min 32 chars)
ENCRYPTION_KEY=

# Redis connection (api, worker)
REDIS_URL=

# Sentry DSN — optional; no-op when unset (api, worker, web, marketing)
SENTRY_DSN=

# Self-hosted ingestion mode (api, worker): webhook (default) | polling
# Set polling when CE cannot expose a public webhook endpoint (PRD §16, §18)
PIPEWATCH_MODE=webhook
