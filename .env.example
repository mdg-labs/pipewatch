# PipeWatch CE — copy to .env before `docker compose up -d`
# Per-app examples for local dev: apps/*/.env.example
# Full reference: docs/internal/PipeWatch_MVP_PRD.md §23
#
# Generate CE infrastructure + auth secrets:
#   bash scripts/generate-ce-secrets.sh --merge .env
# Or print values to paste manually:
#   bash scripts/generate-ce-secrets.sh

# Edition — drives all feature flags (ce | cloud)
PIPEWATCH_EDITION=ce

# CE embedded Postgres (Compose only — not used for local monorepo dev)
POSTGRES_DB=pipewatch
POSTGRES_USER=pipewatch
POSTGRES_PASSWORD=

# CE embedded Redis (Compose only — requirepass; internal network, not host-published)
REDIS_PASSWORD=

# AES-256-GCM key for encrypting sensitive values at rest (min 32 chars)
ENCRYPTION_KEY=

# HS256 signing secrets for access and refresh tokens (min 32 chars each)
JWT_SECRET=
JWT_REFRESH_SECRET=

# GitHub App credentials — runtime names (create a GitHub App; see README CE quickstart)
# Phase/GHA storage uses GH_* keys; sync-secrets maps GH_* → GITHUB_* on Fly (Decision #33)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Public URLs — set to your reachable hostnames in production
# APP_URL and MARKETING_URL are the API CORS allowlist (browser credentialed requests)
APP_URL=
MARKETING_URL=
# Public API origin — OAuth callbacks; must match GitHub App callback host (same value as NEXT_PUBLIC_API_URL)
PUBLIC_API_URL=
NEXT_PUBLIC_API_URL=
# Optional — override auto-derived shared cookie domain when app/API hosts differ (cloud: usually auto `pipewatch.app`)
COOKIE_DOMAIN=

# Self-hosted ingestion mode (api, worker): webhook (default) | polling
# Use polling when CE cannot expose a public webhook endpoint (PRD §16, §23)
PIPEWATCH_MODE=webhook

# Pipeline run retention in days (worker; default: 30)
RETENTION_DAYS=30

# Email — optional; invite links shown in UI when SMTP_HOST is unset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry DSN — optional; no-op when unset (api, worker, web)
SENTRY_DSN=
