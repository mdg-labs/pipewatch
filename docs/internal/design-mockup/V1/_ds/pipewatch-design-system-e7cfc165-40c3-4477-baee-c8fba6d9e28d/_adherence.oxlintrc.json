{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlay/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|rounded|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:2xs|xs|sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of '2xs' | 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|mono|pill|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, mono, pill, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|success|failure|outline)$/]",
        "message": "<Badge> variant must be one of 'default' | 'accent' | 'success' | 'failure' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Badge> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|icon|iconPosition|iconOnly|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, icon, iconPosition, iconOnly."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Button> iconPosition must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|actions|footer|size|interactive|flush|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, actions, footer, size, interactive, flush, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Card> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|indeterminate|hint|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, disabled, indeterminate, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|description|children|footer|size|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, description, children, footer, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Dialog> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|actions|className|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, actions, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|hint|mono|prefix|suffix|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, hint, mono, prefix, suffix, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Input> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|name|value|hint|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label, checked, onChange, disabled, name, value, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|hint|disabled|key|ref|className|style|children)$/]",
        "message": "<RadioOption> doesn't accept that prop. Declared props: value, label, hint, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='RepoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|org|branch|status|lastRunTime|duration|trend|onClick|key|ref|className|style|children)$/]",
        "message": "<RepoCard> doesn't accept that prop. Declared props: name, org, branch, status, lastRunTime, duration, trend, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='RepoCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|failure|running|cancelled|skipped|queued)$/]",
        "message": "<RepoCard> status must be one of 'success' | 'failure' | 'running' | 'cancelled' | 'skipped' | 'queued'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunPulse'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|ring|key|ref|className|style|children)$/]",
        "message": "<RunPulse> doesn't accept that prop. Declared props: size, label, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|width|height|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: variant, width, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:line|block|circle|rounded)$/]",
        "message": "<Skeleton> variant must be one of 'line' | 'block' | 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|color|strokeWidth|showArea|showDot|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, color, strokeWidth, showArea, showDot."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|size|showDot|showIcon|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, label, size, showDot, showIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|failure|running|cancelled|skipped|queued)$/]",
        "message": "<StatusBadge> status must be one of 'success' | 'failure' | 'running' | 'cancelled' | 'skipped' | 'queued'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<StatusBadge> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|size|hint|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, onChange, disabled, size, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|count|disabled|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon, count, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|variant|onDismiss|duration|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: title, description, variant, onDismiss, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|success|error|warning|info)$/]",
        "message": "<Toast> variant must be one of 'default' | 'success' | 'error' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToastItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|key|ref|className|style|children)$/]",
        "message": "<ToastItem> doesn't accept that prop. Declared props: id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:content|children|position|delay|mono|disabled|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: content, children, position, delay, mono, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='position'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> position must be one of 'top' | 'bottom' | 'left' | 'right'."
      }
    ]
  },
