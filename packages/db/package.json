{
  "name": "@pipewatch/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./neon": {
      "types": "./dist/neon.d.ts",
      "default": "./dist/neon.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "devDependencies": {
    "@pipewatch/config": "workspace:*",
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
